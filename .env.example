# ============================================================================
# Environment Variable Templates
# ============================================================================
# Copy each example to its real file and fill in actual values:
#
#   cp .env.db.example  .env.db
#   cp .env.backend.example  .env.backend
#
# NEVER commit .env.db or .env.backend to git — they're in .gitignore.
