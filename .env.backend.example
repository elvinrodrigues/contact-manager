# ============================================================================
# .env.backend.example — Go backend environment
# ============================================================================
# cp .env.backend.example .env.backend
#
# DB credentials (user/password/dbname) come from .env.db — NOT duplicated here.
# The Go code builds the DSN at runtime from POSTGRES_* + DB_HOST vars.
# ============================================================================

# Database host — 'db' resolves via Docker DNS; 'localhost' for local dev.
DB_HOST=db
DB_SSLMODE=disable

# JWT signing key — generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand

# Resend email API key
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# App config
BASE_URL=http://localhost:3000
DEBUG_EMAIL=false
FORCE_EMAIL=true
